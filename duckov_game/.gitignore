# Godot 4.x .gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Godot runtime crash logs
crash_log.*.txt

# Build results
builds/
*.apk
*.aab
*.ipa
*.pck
*.zip

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Project specific
save_data/
